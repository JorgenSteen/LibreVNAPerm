<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ProbeSetupDialog</class>
 <widget class="QDialog" name="ProbeSetupDialog">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>520</width>
    <height>480</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Probe setup</string>
  </property>
  <layout class="QVBoxLayout" name="verticalLayout">
   <item>
    <layout class="QHBoxLayout" name="modeLayout">
     <item>
      <widget class="QRadioButton" name="individualMode">
       <property name="text">
        <string>Select files individually</string>
       </property>
       <property name="checked">
        <bool>true</bool>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QRadioButton" name="directoryModeButton">
       <property name="toolTip">
        <string>Point at a directory containing the standard measurements for all temperatures. The files matching the configured temperature are selected automatically by filename.</string>
       </property>
       <property name="text">
        <string>From directory</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QRadioButton" name="probeModeButton">
       <property name="toolTip">
        <string>Use an imported probe from the probe library: select the probe and the liquid temperature, the matching standard files are picked automatically.</string>
       </property>
       <property name="text">
        <string>Probe</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <widget class="QStackedWidget" name="modeStack">
     <widget class="QWidget" name="filesPage">
      <layout class="QVBoxLayout" name="filesPageLayout">
       <item>
        <widget class="QGroupBox" name="standardsBox">
         <property name="title">
          <string>Probe standard measurements (S11)</string>
         </property>
         <layout class="QFormLayout" name="formLayout">
          <item row="0" column="0">
           <widget class="QLabel" name="airLabel">
            <property name="text">
             <string>Open (air):</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <widget class="TouchstoneImport" name="airFile" native="true"/>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="waterLabel">
            <property name="text">
             <string>Water:</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <widget class="TouchstoneImport" name="waterFile" native="true"/>
          </item>
          <item row="2" column="0">
           <widget class="QLabel" name="saltwaterLabel">
            <property name="text">
             <string>Saltwater:</string>
            </property>
           </widget>
          </item>
          <item row="2" column="1">
           <widget class="TouchstoneImport" name="saltwaterFile" native="true"/>
          </item>
         </layout>
        </widget>
       </item>
      </layout>
     </widget>
     <widget class="QWidget" name="directoryPage">
      <layout class="QVBoxLayout" name="directoryPageLayout">
       <item>
        <widget class="QGroupBox" name="directoryBox">
         <property name="title">
          <string>Standards directory</string>
         </property>
         <layout class="QVBoxLayout" name="directoryBoxLayout">
          <item>
           <layout class="QHBoxLayout" name="directoryLayout">
            <item>
             <widget class="QLineEdit" name="directory">
              <property name="toolTip">
               <string>Directory (searched including subdirectories) containing the standard measurement files. Filenames must contain "open" (air standard), "water" and "salt(water)", with a temperature suffix like "-22p5c" (= 22.5 °C) for the temperature-dependent liquids.</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="browseDirectory">
              <property name="maximumSize">
               <size>
                <width>30</width>
                <height>16777215</height>
               </size>
              </property>
              <property name="text">
               <string>...</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item>
           <widget class="QLabel" name="resolvedPreview">
            <property name="text">
             <string/>
            </property>
            <property name="wordWrap">
             <bool>true</bool>
            </property>
           </widget>
          </item>
          <item>
           <spacer name="directorySpacer">
            <property name="orientation">
             <enum>Qt::Vertical</enum>
            </property>
            <property name="sizeHint" stdset="0">
             <size>
              <width>20</width>
              <height>10</height>
             </size>
            </property>
           </spacer>
          </item>
         </layout>
        </widget>
       </item>
      </layout>
     </widget>
     <widget class="QWidget" name="probePage">
      <layout class="QVBoxLayout" name="probePageLayout">
       <item>
        <widget class="QGroupBox" name="probeBox">
         <property name="title">
          <string>Probe</string>
         </property>
         <layout class="QFormLayout" name="probeFormLayout">
          <item row="0" column="0">
           <widget class="QLabel" name="probeLabel">
            <property name="text">
             <string>Probe:</string>
            </property>
           </widget>
          </item>
          <item row="0" column="1">
           <layout class="QHBoxLayout" name="probeSelectLayout">
            <item>
             <widget class="QComboBox" name="probeCombo">
              <property name="sizePolicy">
               <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
                <horstretch>0</horstretch>
                <verstretch>0</verstretch>
               </sizepolicy>
              </property>
              <property name="toolTip">
               <string>Probes imported into the probe library.</string>
              </property>
             </widget>
            </item>
            <item>
             <widget class="QPushButton" name="importProbeButton">
              <property name="toolTip">
               <string>Import a directory of exported probe data files into the probe library.</string>
              </property>
              <property name="text">
               <string>Import probe...</string>
              </property>
             </widget>
            </item>
           </layout>
          </item>
          <item row="1" column="0">
           <widget class="QLabel" name="probeTemperatureLabel">
            <property name="text">
             <string>Temperature:</string>
            </property>
           </widget>
          </item>
          <item row="1" column="1">
           <widget class="QComboBox" name="probeTemperature">
            <property name="toolTip">
             <string>Liquid temperatures for which the probe contains a complete standard set.</string>
            </property>
           </widget>
          </item>
          <item row="2" column="0" colspan="2">
           <widget class="QLabel" name="probeInfo">
            <property name="text">
             <string/>
            </property>
            <property name="wordWrap">
             <bool>true</bool>
            </property>
           </widget>
          </item>
         </layout>
        </widget>
       </item>
       <item>
        <spacer name="probeSpacer">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>10</height>
          </size>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>
    </widget>
   </item>
   <item>
    <layout class="QFormLayout" name="settingsLayout">
     <item row="0" column="0">
      <widget class="QLabel" name="temperatureLabel">
       <property name="text">
        <string>Liquid temperature:</string>
       </property>
      </widget>
     </item>
     <item row="0" column="1">
      <widget class="QDoubleSpinBox" name="temperature">
       <property name="toolTip">
        <string>Temperature of the standard liquids during their measurement. Used to evaluate the temperature-dependent reference models of water and saltwater, and to select the matching files in directory mode.</string>
       </property>
       <property name="suffix">
        <string> °C</string>
       </property>
       <property name="decimals">
        <number>1</number>
       </property>
       <property name="minimum">
        <double>0.000000000000000</double>
       </property>
       <property name="maximum">
        <double>50.000000000000000</double>
       </property>
       <property name="singleStep">
        <double>0.500000000000000</double>
       </property>
       <property name="value">
        <double>22.500000000000000</double>
       </property>
      </widget>
     </item>
     <item row="1" column="0">
      <widget class="QLabel" name="epsSourceLabel">
       <property name="text">
        <string>Known ε* of standards:</string>
       </property>
      </widget>
     </item>
     <item row="1" column="1">
      <widget class="QComboBox" name="epsSource">
       <property name="toolTip">
        <string>Where the known permittivity of the calibration standards comes from: the permittivity columns of the standard files themselves (custom file format), or built-in reference models (air = 1, water: Debye, saltwater 0.9% NaCl: Cole-Cole) evaluated at the configured temperature.</string>
       </property>
       <item>
        <property name="text">
         <string>File permittivity columns</string>
        </property>
       </item>
       <item>
        <property name="text">
         <string>Reference models (Debye / Cole-Cole)</string>
        </property>
       </item>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <spacer name="verticalSpacer">
     <property name="orientation">
      <enum>Qt::Vertical</enum>
     </property>
     <property name="sizeHint" stdset="0">
      <size>
       <width>20</width>
       <height>10</height>
      </size>
     </property>
    </spacer>
   </item>
   <item>
    <widget class="QDialogButtonBox" name="buttonBox">
     <property name="orientation">
      <enum>Qt::Horizontal</enum>
     </property>
     <property name="standardButtons">
      <set>QDialogButtonBox::Cancel|QDialogButtonBox::Ok</set>
     </property>
    </widget>
   </item>
  </layout>
 </widget>
 <customwidgets>
  <customwidget>
   <class>TouchstoneImport</class>
   <extends>QWidget</extends>
   <header>CustomWidgets/touchstoneimport.h</header>
   <container>1</container>
  </customwidget>
 </customwidgets>
 <resources/>
 <connections>
  <connection>
   <sender>buttonBox</sender>
   <signal>accepted()</signal>
   <receiver>ProbeSetupDialog</receiver>
   <slot>accept()</slot>
  </connection>
  <connection>
   <sender>buttonBox</sender>
   <signal>rejected()</signal>
   <receiver>ProbeSetupDialog</receiver>
   <slot>reject()</slot>
  </connection>
 </connections>
</ui>
